<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Aleem Family Golf — Driving range, adventure golf, lessons & café in Islamabad.">
  <link rel="shortcut icon" href="/images/logo.png" type="image/png"/>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.4.0/fonts/remixicon.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div id="cursor"></div>
  <div id="cursor-blur"></div>

  <nav id="nav">
    <a href="/" class="nav-logo">
      <img src="/images/logo.png" alt="Aleem Family Golf Logo"/>
    </a>
    <div class="nav-links">
      <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a>
      <a href="/lessons" class="<%= currentPage === 'lessons' ? 'active' : '' %>">Golf Lessons</a>
      <a href="/adventure" class="<%= currentPage === 'adventure' ? 'active' : '' %>">Adventure Golf</a>
      <a href="/book" class="<%= currentPage === 'book' ? 'active' : '' %>">Book Now</a>
      <a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact</a>
    </div>
    <button class="nav-toggle" aria-label="Toggle menu">
      <i class="ri-menu-3-line"></i>
    </button>
  </nav>
