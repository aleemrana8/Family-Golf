<%- include('partials/header') %>

<video autoplay loop muted playsinline id="hero-video"
  src="https://sidcupfamilygolf.com/wp-content/uploads/2023/02/hero.mp4"></video>

<div id="main">
  <!-- HERO -->
  <section id="page1" class="hero-section">
    <h1>EAT. DRINK. PLAY.</h1>
    <h2>WELCOME TO SIDCUP FAMILY GOLF!</h2>
    <p>
      Sidcup Family Golf is a multipurpose golf facility located in Sidcup,
      South East London. Passionate about technology, player development and
      making golf fun and accessible to everyone.
    </p>
    <a href="/book" class="btn btn-primary hero-cta">
      <i class="ri-calendar-check-line"></i> Book Your Visit
    </a>
    <div id="arrow">
      <i class="ri-arrow-down-line"></i>
    </div>
  </section>

  <!-- SCROLLING MARQUEE -->
  <section id="page2">
    <div id="scroller">
      <div class="scroller-in">
        <h4>TOPTRACER RANGE</h4>
        <h4>GOLF LESSONS</h4>
        <h4>ADVENTURE GOLF</h4>
        <h4>COFFEE SHOP</h4>
        <h4>LEAGUES</h4>
      </div>
      <div class="scroller-in">
        <h4>TOPTRACER RANGE</h4>
        <h4>GOLF LESSONS</h4>
        <h4>ADVENTURE GOLF</h4>
        <h4>COFFEE SHOP</h4>
        <h4>LEAGUES</h4>
      </div>
    </div>

    <!-- ABOUT US -->
    <div id="about-us">
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/home-about-1-300x200.jpg?strip=all&lossy=1&sharp=1&ssl=1" alt="Driving Range"/>
      <div id="about-us-in">
        <h3>ABOUT US</h3>
        <p>
          Home to a 46-bay, multi-tier, floodlit driving range, powered by
          Toptracer Range technology. Complimented by a practice green and
          bunker, coffee shop and American Golf Store. There truly is
          something for everyone as we also boast two outdoor 18-hole
          dinosaur themed crazy golf courses.
        </p>
      </div>
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/home-about-2-300x200.jpg?strip=all&lossy=1&sharp=1&ssl=1" alt="Adventure Golf"/>
    </div>

    <!-- SERVICE CARDS -->
    <div id="cards-container">
      <div class="card" id="card1">
        <div class="overlay">
          <h4>TopTracer Range</h4>
          <p>46-bay floodlit driving range with cutting-edge ball tracking. See distance, trajectory and accuracy in real-time.</p>
          <a href="/book" class="btn btn-dark btn-sm">Book Range</a>
        </div>
      </div>
      <div class="card" id="card2">
        <div class="overlay">
          <h4>Adventure Golf</h4>
          <p>Two 18-hole outdoor dinosaur-themed crazy golf courses. Fun for the whole family, rain or shine!</p>
          <a href="/adventure" class="btn btn-dark btn-sm">Learn More</a>
        </div>
      </div>
      <div class="card" id="card3">
        <div class="overlay">
          <h4>Golf Lessons</h4>
          <p>Expert PGA-qualified instructors for all levels. Improve your game with personalized coaching sessions.</p>
          <a href="/lessons" class="btn btn-dark btn-sm">View Lessons</a>
        </div>
      </div>
    </div>

    <!-- NEWSLETTER -->
    <div id="green-div">
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/themes/puttosaurus/img/dots-side.svg" alt=""/>
      <div class="newsletter-form">
        <h4>GET NEWS & SPECIAL OFFERS STRAIGHT TO YOUR INBOX</h4>
        <form id="newsletter-form" class="inline-form">
          <input type="email" name="email" placeholder="Enter your email address" required/>
          <button type="submit" class="btn btn-dark">Subscribe <i class="ri-send-plane-fill"></i></button>
        </form>
        <p class="form-message" id="newsletter-msg"></p>
      </div>
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/themes/puttosaurus/img/dots-side.svg" alt=""/>
    </div>
  </section>

  <!-- REVIEWS -->
  <section id="page3" class="reviews-section">
    <h3 class="section-title">WHAT OUR VISITORS SAY</h3>
    <div class="reviews-grid">
      <% reviews.forEach(function(review) { %>
        <div class="review-card">
          <div class="review-stars">
            <% for(let i = 0; i < review.rating; i++) { %>
              <i class="ri-star-fill"></i>
            <% } %>
            <% for(let i = review.rating; i < 5; i++) { %>
              <i class="ri-star-line"></i>
            <% } %>
          </div>
          <p class="review-text">"<%= review.comment %>"</p>
          <p class="review-author">— <%= review.name %></p>
        </div>
      <% }) %>
    </div>
    <img id="colon1" src="https://eiwgew27fhz.exactdn.com/wp-content/themes/puttosaurus/img/quote-left.svg" alt=""/>
    <img id="colon2" src="https://eiwgew27fhz.exactdn.com/wp-content/themes/puttosaurus/img/quote-right.svg" alt=""/>
  </section>

  <!-- CTA SECTION -->
  <section id="page4">
    <h1>WHAT ARE YOU WAITING FOR?</h1>
    <div class="elem">
      <h2>TOPTRACER RANGE</h2>
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/page-toptracer-1024x683.jpg?strip=all&lossy=1&sharp=1&ssl=1" alt="TopTracer"/>
    </div>
    <div class="elem">
      <h2>GOLF LESSONS</h2>
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/page-lessons-1024x683.jpg?strip=all&lossy=1&sharp=1&ssl=1" alt="Lessons"/>
    </div>
    <div class="elem">
      <h2>ADVENTURE GOLF</h2>
      <img src="https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/page-ag-1024x682.jpg?strip=all&lossy=1&sharp=1&ssl=1" alt="Adventure Golf"/>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
