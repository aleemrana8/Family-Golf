<%- include('partials/header') %>

<div id="main" class="page-content">
  <section class="page-hero lessons-hero">
    <h1>GOLF LESSONS</h1>
    <p>Expert coaching for every level — from beginner to advanced</p>
  </section>

  <section class="content-section">
    <div class="content-grid">
      <div class="content-card">
        <div class="content-card-icon"><i class="ri-user-line"></i></div>
        <h3>Private Lessons</h3>
        <p>One-on-one sessions with PGA-qualified professionals. Tailored to your specific needs with video analysis and personalised training plans.</p>
        <div class="price-tag">From £45 / 30 min</div>
        <a href="/book?activity=private-lesson" class="btn btn-primary btn-sm">Book Now</a>
      </div>
      <div class="content-card">
        <div class="content-card-icon"><i class="ri-group-line"></i></div>
