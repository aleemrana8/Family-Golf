<%- include('partials/header') %>

<div id="main" class="page-content">
  <section class="page-hero adventure-hero">
    <h1>ADVENTURE GOLF</h1>
    <p>Two 18-hole dinosaur themed crazy golf courses for the whole family</p>
  </section>

  <section class="content-section">
    <div class="adventure-grid">
      <div class="adventure-item">
        <div class="adventure-img" style="background-image: url('https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/hero-4-1024x1024.jpg?strip=all&lossy=1&sharp=1&ssl=1')"></div>
        <div class="adventure-info">
          <h3>🦕 Jurassic Course</h3>
          <p>Navigate 18 holes through a prehistoric jungle. Encounter life-size dinosaurs, waterfalls and caves. Suitable for all ages — the perfect family adventure!</p>
          <div class="adventure-details">
            <span><i class="ri-flag-line"></i> 18 Holes</span>
            <span><i class="ri-time-line"></i> ~60 min</span>
            <span><i class="ri-group-line"></i> All Ages</span>
          </div>
          <div class="price-tag">Adults PKR 2,500 · Children PKR 2,000</div>
          <a href="/book?activity=jurassic-course" class="btn btn-primary">Book This Course</a>
        </div>
      </div>
      <div class="adventure-item reverse">
        <div class="adventure-img" style="background-image: url('https://eiwgew27fhz.exactdn.com/wp-content/uploads/2023/02/page-ag-1024x682.jpg?strip=all&lossy=1&sharp=1&ssl=1')"></div>
        <div class="adventure-info">
          <h3>🌋 Volcano Course</h3>
          <p>Take on the challenge of our volcano-themed course with erupting features, lava rivers and tricky obstacles. A step up in difficulty for those who dare!</p>
          <div class="adventure-details">
            <span><i class="ri-flag-line"></i> 18 Holes</span>
            <span><i class="ri-time-line"></i> ~75 min</span>
            <span><i class="ri-group-line"></i> Ages 5+</span>
          </div>
          <div class="price-tag">Adults PKR 3,000 · Children PKR 2,500</div>
          <a href="/book?activity=volcano-course" class="btn btn-primary">Book This Course</a>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section alt-bg">
    <h2 class="section-heading">ADVENTURE GOLF INFO</h2>
    <div class="features-row">
      <div class="feature-item">
        <i class="ri-sun-line"></i>
        <h4>Open All Year</h4>
        <p>Rain or shine, our courses are open every day</p>
      </div>
      <div class="feature-item">
        <i class="ri-flashlight-line"></i>
        <h4>Floodlit</h4>
        <p>Play into the evening with full course lighting</p>
      </div>
      <div class="feature-item">
        <i class="ri-cake-2-line"></i>
        <h4>Party Packages</h4>
        <p>Birthday party packages available with food & drink</p>
      </div>
      <div class="feature-item">
        <i class="ri-wheelchair-line"></i>
        <h4>Accessible</h4>
        <p>Wheelchair-friendly pathways throughout</p>
      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
